// HYBRID INDEX — schéma de données (cf. docs/architecture.md §3).
// Deux schémas Postgres : `app.*` (propriété api) et `scoring.*` (propriété score-service).
// Les liens vers scoring.* sont des champs uuid logiques (pas de FK cross-schema stricte, §3.3).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  // Moteurs : natif (dev) + Alpine/musl OpenSSL 3 (image Docker node:22-alpine) — sinon Prisma
  // cherche libssl 1.1 qui n'existe pas sur Alpine récent.
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["app", "scoring"]
}

// ----------------------------- Enums -----------------------------

enum Sex {
  male
  female

  @@schema("app")
}

enum EquipmentPref {
  none
  equipped
  both

  @@schema("app")
}

enum Goal {
  hyrox
  crossfit_strength
  all_round

  @@schema("app")
}

enum AttributeKey {
  engine
  speed
  strength
  power
  muscular_endurance
  hybrid

  @@schema("app")
}

enum WodType {
  for_time
  amrap
  emom
  chipper
  strength
  interval
  tabata
  distance

  @@schema("app")
}

enum ScoreType {
  time
  reps
  load
  distance

  @@schema("app")
}

enum ResultSource {
  declared
  verified

  @@schema("app")
}

enum Visibility {
  public
  private

  @@schema("app")
}

enum Rank {
  rookie
  bronze
  silver
  gold
  platinum
  diamond
  elite

  @@schema("app")
}

enum DistributionSource {
  public
  community

  @@schema("app")
}

enum ReactionTarget {
  wod_result
  badge
  rank_up

  @@schema("app")
}

enum BadgeCategory {
  progression
  collection
  performance
  consistency
  social

  @@schema("app")
}

enum ResultReview {
  ok
  pending_review
  rejected

  @@schema("app")
}

enum ScoringStatus {
  draft
  active
  superseded

  @@schema("scoring")
}

enum FeedEventType {
  pr
  wod_logged
  rank_up
  badge_unlocked
  member_joined

  @@schema("app")
}

// ----------------------------- app.* -----------------------------

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  email               String?   @unique
  passwordHash        String?   @map("password_hash")
  dateOfBirth         DateTime  @map("date_of_birth") @db.Date
  ageVerified         Boolean   @default(false) @map("age_verified")
  consents            Json
  status              String    @default("active")
  deletionRequestedAt DateTime? @map("deletion_requested_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  identities        AuthIdentity[]
  avatar            Avatar?
  profile           Profile?
  hybridIndex       HybridIndex?
  attributeScores   AttributeScore[]
  wodResults        WodResult[]
  wodsCreated       Wod[]             @relation("WodCreator")
  feedEvents        FeedEvent[]       @relation("FeedActor")
  reactions         Reaction[]        @relation("ReactionAuthor")
  streak            Streak?
  notificationPrefs NotificationPrefs?
  userBadges        UserBadge[]
  following         Follow[]          @relation("Follower")
  followers         Follow[]          @relation("Followee")
  progressEvents    ProgressEvent[]
  posts             Post[]            @relation("PostAuthor")
  postReactions     PostReaction[]    @relation("PostReactionAuthor")
  reports           Report[]          @relation("Reporter")
  clubsOwned        Club[]            @relation("ClubOwner")
  clubMemberships   ClubMember[]
  conversationsA    Conversation[]    @relation("ConvUserA")
  conversationsB    Conversation[]    @relation("ConvUserB")
  messages          Message[]         @relation("MessageSender")
  blocksMade        Block[]           @relation("Blocker")
  blocksReceived    Block[]           @relation("Blocked")

  @@map("user")
  @@schema("app")
}

// Classement de progression hebdomadaire (B1) — ledger durable des points d'effort (EP).
model ProgressEvent {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  weekKey      String   @map("week_key") // isoWeekKey(performedAt), ex. "2026-W25"
  type         String // wod_logged | active_day | pr | new_wod | attr_unlocked
  epAwarded    Int      @map("ep_awarded") // 0 si plafonné
  cappedReason String?  @map("capped_reason")
  refId        String?  @map("ref_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([weekKey, userId])
  @@index([userId, weekKey])
  @@map("progress_event")
  @@schema("app")
}

// Agrégat hebdo par utilisateur (repli classement + meilleure semaine perso).
model ProgressWeekly {
  userId      String  @map("user_id") @db.Uuid
  weekKey     String  @map("week_key")
  sex         Sex
  ep          Int     @default(0)
  activeDays  Int     @default(0) @map("active_days")
  prCount     Int     @default(0) @map("pr_count")

  @@id([userId, weekKey])
  @@index([weekKey, sex, ep(sort: Desc)])
  @@map("progress_weekly")
  @@schema("app")
}

// ----------------------------- Réseau social (Phase C) -----------------------------

enum PostKind {
  text
  perf_share
  photo

  @@schema("app")
}

enum ModerationStatus {
  visible
  hidden
  removed

  @@schema("app")
}

enum ClubRole {
  owner
  member

  @@schema("app")
}

enum ClubInviteStatus {
  pending
  accepted
  declined
  revoked

  @@schema("app")
}

enum ReportTargetType {
  post
  message
  club
  user

  @@schema("app")
}

enum ReportReason {
  spam
  harassment
  inappropriate
  cheating
  other

  @@schema("app")
}

enum ReportStatus {
  open
  reviewed
  actioned
  dismissed

  @@schema("app")
}

model Post {
  id            String           @id @default(uuid()) @db.Uuid
  authorId      String           @map("author_id") @db.Uuid
  kind          PostKind
  body          String?          @db.VarChar(500)
  wodResultId   String?          @map("wod_result_id") @db.Uuid
  photoUrl      String?          @map("photo_url")
  clubId        String?          @map("club_id") @db.Uuid
  status        ModerationStatus @default(visible)
  visibility    Visibility       @default(public)
  reactionCount Int              @default(0) @map("reaction_count")
  reportCount   Int              @default(0) @map("report_count")
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  author    User           @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reactions PostReaction[]

  @@index([authorId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([clubId, createdAt(sort: Desc)])
  @@map("post")
  @@schema("app")
}

model PostReaction {
  id         String   @id @default(uuid()) @db.Uuid
  postId     String   @map("post_id") @db.Uuid
  fromUserId String   @map("from_user_id") @db.Uuid
  emoji      String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  fromUser User @relation("PostReactionAuthor", fields: [fromUserId], references: [id], onDelete: Cascade)

  @@unique([postId, fromUserId])
  @@index([postId])
  @@map("post_reaction")
  @@schema("app")
}

model Club {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @db.VarChar(40)
  slug        String           @unique
  description String?          @db.VarChar(280)
  ownerId     String           @map("owner_id") @db.Uuid
  visibility  Visibility       @default(public)
  status      ModerationStatus @default(visible)
  memberCount Int              @default(0) @map("member_count")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner   User         @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members ClubMember[]
  invites ClubInvite[]

  @@index([status, memberCount(sort: Desc)])
  @@map("club")
  @@schema("app")
}

model ClubMember {
  clubId   String   @map("club_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     ClubRole @default(member)
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([clubId, userId])
  @@index([userId])
  @@index([clubId, joinedAt])
  @@map("club_member")
  @@schema("app")
}

model ClubInvite {
  id          String           @id @default(uuid()) @db.Uuid
  clubId      String           @map("club_id") @db.Uuid
  inviterId   String           @map("inviter_id") @db.Uuid
  inviteeId   String           @map("invitee_id") @db.Uuid
  status      ClubInviteStatus @default(pending)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  respondedAt DateTime?        @map("responded_at") @db.Timestamptz(6)

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, inviteeId])
  @@index([inviteeId, status])
  @@map("club_invite")
  @@schema("app")
}

model Block {
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("block")
  @@schema("app")
}

model Conversation {
  id            String    @id @default(uuid()) @db.Uuid
  userAId       String    @map("user_a_id") @db.Uuid
  userBId       String    @map("user_b_id") @db.Uuid
  lastMessageAt DateTime? @map("last_message_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  userA    User      @relation("ConvUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User      @relation("ConvUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userAId, userBId])
  @@index([userAId, lastMessageAt(sort: Desc)])
  @@index([userBId, lastMessageAt(sort: Desc)])
  @@map("conversation")
  @@schema("app")
}

model Message {
  id             String           @id @default(uuid()) @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  senderId       String           @map("sender_id") @db.Uuid
  body           String           @db.VarChar(2000)
  status         ModerationStatus @default(visible)
  readAt         DateTime?        @map("read_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("message")
  @@schema("app")
}

model Report {
  id         String           @id @default(uuid()) @db.Uuid
  reporterId String           @map("reporter_id") @db.Uuid
  targetType ReportTargetType @map("target_type")
  targetId   String           @map("target_id") @db.Uuid
  reason     ReportReason
  note       String?          @db.VarChar(500)
  status     ReportStatus     @default(open)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt DateTime?        @map("resolved_at") @db.Timestamptz(6)

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([status, createdAt])
  @@map("report")
  @@schema("app")
}

model AuthIdentity {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  provider        String
  providerSubject String   @map("provider_subject")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@map("auth_identity")
  @@schema("app")
}

model Avatar {
  userId            String   @id @map("user_id") @db.Uuid
  skinTone          Int      @map("skin_tone") @db.SmallInt
  hairStyle         Int      @map("hair_style") @db.SmallInt
  hairColor         Int      @map("hair_color") @db.SmallInt
  beardStyle        Int?     @map("beard_style") @db.SmallInt
  accessory         Int      @default(0) @map("accessory") @db.SmallInt
  background        Int      @default(0) @map("background") @db.SmallInt
  photoData         String?  @map("photo_data") // image de profil (data URL base64, optionnelle)
  equippedCosmetics Json     @map("equipped_cosmetics")
  unlockedCosmetics Json     @map("unlocked_cosmetics")
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("avatar")
  @@schema("app")
}

model Profile {
  userId        String        @id @map("user_id") @db.Uuid
  displayName   String        @unique @map("display_name")
  sex           Sex
  goal          Goal
  equipmentPref EquipmentPref @map("equipment_pref")
  rank          Rank          @default(rookie)
  visibility    Visibility    @default(public)
  city          String?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sex])
  @@index([rank])
  @@map("profile")
  @@schema("app")
}

model HybridIndex {
  userId           String   @id @map("user_id") @db.Uuid
  value            Int
  percentile       Decimal  @db.Decimal(5, 4)
  isProvisional    Boolean  @map("is_provisional")
  isEstimated      Boolean  @map("is_estimated")
  radarCoverage    Int      @map("radar_coverage") @db.SmallInt
  projectedValue   Int?     @map("projected_value")
  confidenceLevel  String   @map("confidence_level")
  // Preuve sociale « population générale » (popnorm-v1) — cosmétique, distincte du percentile compétitif.
  populationPercentile Decimal? @map("population_percentile") @db.Decimal(5, 4)
  populationBand       String?  @map("population_band")
  // Position dans la ligue au dernier recalcul (snapshot pour détecter « quelqu'un t'a dépassé »).
  leaguePosition   Int?     @map("league_position")
  scoringVersionId String   @map("scoring_version_id") @db.Uuid
  computedAt       DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([value(sort: Desc)])
  @@map("hybrid_index")
  @@schema("app")
}

model AttributeScore {
  userId           String       @map("user_id") @db.Uuid
  attribute        AttributeKey
  score            Int
  percentile       Decimal      @db.Decimal(5, 4)
  unlocked         Boolean
  isEstimated      Boolean      @map("is_estimated")
  isStale          Boolean      @map("is_stale")
  bestResultId     String?      @map("best_result_id") @db.Uuid
  scoringVersionId String       @map("scoring_version_id") @db.Uuid
  lastUpdated      DateTime     @updatedAt @map("last_updated") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, attribute])
  @@index([attribute, score(sort: Desc)])
  @@map("attribute_score")
  @@schema("app")
}

model Wod {
  id                String         @id @default(cuid())
  name              String
  isBenchmark       Boolean        @map("is_benchmark")
  isCustom          Boolean        @default(false) @map("is_custom")
  createdById       String?        @map("created_by_id") @db.Uuid
  type              WodType
  requiresEquipment Boolean        @map("requires_equipment")
  targetAttributes  AttributeKey[] @map("target_attributes")
  scoreType         ScoreType      @map("score_type")
  movements         Json
  timeCapSec        Int?           @map("time_cap_sec")
  rounds            Int?
  visibility        Visibility     @default(public)
  calibration       String         @default("estimated")
  resultCount       Int            @default(0) @map("result_count")
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  creator    User?       @relation("WodCreator", fields: [createdById], references: [id], onDelete: SetNull)
  results    WodResult[]

  @@index([requiresEquipment])
  @@index([isCustom, visibility, createdAt(sort: Desc)])
  @@index([createdById])
  @@map("wod")
  @@schema("app")
}

model WodResult {
  id                 String         @id @default(uuid()) @db.Uuid
  userId             String         @map("user_id") @db.Uuid
  wodId              String         @map("wod_id")
  sex                Sex
  rawResult          Decimal        @map("raw_result")
  distanceMeters     Int?           @map("distance_meters")
  rxCompliant        Boolean        @default(true) @map("rx_compliant")
  subScore           Int?           @map("sub_score")
  percentile         Decimal?       @db.Decimal(5, 4)
  attributesAffected AttributeKey[] @map("attributes_affected")
  source             ResultSource   @default(declared)
  review             ResultReview   @default(ok)
  scoringVersionId   String?        @map("scoring_version_id") @db.Uuid
  idempotencyKey     String?        @map("idempotency_key")
  visibility         Visibility     @default(public)
  performedAt        DateTime       @map("performed_at") @db.Timestamptz(6)
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  wod  Wod  @relation(fields: [wodId], references: [id])

  @@unique([userId, idempotencyKey])
  @@index([wodId, sex, subScore(sort: Desc)])
  @@index([userId, wodId, performedAt(sort: Desc)])
  @@index([userId, performedAt(sort: Desc)])
  @@map("wod_result")
  @@schema("app")
}

model League {
  id    String @id
  sex   Sex
  label String

  @@map("league")
  @@schema("app")
}

model Streak {
  userId                 String    @id @map("user_id") @db.Uuid
  current                Int       @default(0)
  best                   Int       @default(0)
  weeklyGoal             Int       @default(3) @map("weekly_goal")
  freezeTokens           Int       @default(1) @map("freeze_tokens")
  freezeTokensRefreshedAt DateTime? @map("freeze_tokens_refreshed_at") @db.Timestamptz(6)
  plannedRest            Boolean   @default(false) @map("planned_rest")
  lastWeekEvaluated      String?   @map("last_week_evaluated")
  lastOutcome            String?   @map("last_outcome")
  validatedActiveWeeks   Int       @default(0) @map("validated_active_weeks")
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streak")
  @@schema("app")
}

model NotificationPrefs {
  userId     String   @id @map("user_id") @db.Uuid
  prefs      Json
  quietHours Json     @map("quiet_hours")
  dailyCap   Int      @default(2) @map("daily_cap")
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_prefs")
  @@schema("app")
}

model Follow {
  followerId String   @map("follower_id") @db.Uuid
  followeeId String   @map("followee_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  follower User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee User @relation("Followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@id([followerId, followeeId])
  @@index([followeeId])
  @@index([followerId, createdAt])
  @@map("follow")
  @@schema("app")
}

model Badge {
  id             String        @id
  category       BadgeCategory
  condition      String
  rarity         String
  cosmeticUnlock String?       @map("cosmetic_unlock")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  userBadges UserBadge[]

  @@map("badge")
  @@schema("app")
}

model UserBadge {
  userId     String   @map("user_id") @db.Uuid
  badgeId    String   @map("badge_id")
  unlockedAt DateTime @default(now()) @map("unlocked_at") @db.Timestamptz(6)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@id([userId, badgeId])
  @@map("user_badge")
  @@schema("app")
}


model FeedEvent {
  id         String        @id @default(uuid()) @db.Uuid
  actorId    String        @map("actor_id") @db.Uuid
  type       FeedEventType
  payload    Json
  visibility Visibility    @default(public)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  actor     User       @relation("FeedActor", fields: [actorId], references: [id], onDelete: Cascade)
  reactions Reaction[]

  @@index([actorId, createdAt(sort: Desc)])
  @@map("feed_event")
  @@schema("app")
}

model Reaction {
  id          String   @id @default(uuid()) @db.Uuid
  fromUserId  String   @map("from_user_id") @db.Uuid
  feedEventId String   @map("feed_event_id") @db.Uuid
  emoji       String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  fromUser  User      @relation("ReactionAuthor", fields: [fromUserId], references: [id], onDelete: Cascade)
  feedEvent FeedEvent @relation(fields: [feedEventId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, feedEventId, emoji])
  @@index([feedEventId])
  @@map("reaction")
  @@schema("app")
}

// --------------------------- scoring.* ---------------------------
// Propriété du score-service, VERSIONNÉ. Liens depuis app.* via uuid logiques.

model ScoringVersion {
  id               String        @id @default(uuid()) @db.Uuid
  semver           String
  status           ScoringStatus
  fParams          Json          @map("f_params")
  attributeWeights Json          @map("attribute_weights")
  freshnessWeeks   Int           @default(26) @map("freshness_weeks") @db.SmallInt
  notes            String?
  activatedAt      DateTime?     @map("activated_at") @db.Timestamptz(6)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("scoring_version")
  @@schema("scoring")
}

model ReferenceDistribution {
  id               String             @id @default(uuid()) @db.Uuid
  wodId            String             @map("wod_id")
  sex              Sex
  source           DistributionSource
  n                Int
  percentileCurve  Json               @map("percentile_curve")
  proReference     Decimal            @map("pro_reference")
  scoringVersionId String             @map("scoring_version_id") @db.Uuid
  computedAt       DateTime           @default(now()) @map("computed_at") @db.Timestamptz(6)

  @@unique([wodId, sex, scoringVersionId])
  @@map("reference_distribution")
  @@schema("scoring")
}

model HybridIndexHistory {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  value            Int
  percentile       Decimal  @db.Decimal(5, 4)
  scoringVersionId String   @map("scoring_version_id") @db.Uuid
  reason           String
  computedAt       DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)

  @@index([userId, computedAt])
  @@map("hybrid_index_history")
  @@schema("scoring")
}

model RecomputeJob {
  id          String    @id @default(uuid()) @db.Uuid
  fromVersion String    @map("from_version") @db.Uuid
  toVersion   String    @map("to_version") @db.Uuid
  status      String
  totalUsers  Int       @map("total_users")
  processed   Int       @default(0)
  startedAt   DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt  DateTime? @map("finished_at") @db.Timestamptz(6)

  @@map("recompute_job")
  @@schema("scoring")
}
