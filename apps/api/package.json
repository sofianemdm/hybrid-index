{
  "name": "@hybrid-index/api",
  "version": "0.0.0",
  "private": true,
  "description": "HYBRID INDEX — API / BFF public mobile (NestJS).",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "node --watch dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "lint": "echo \"(lint api: TODO eslint)\""
  },
  "dependencies": {
    "@hybrid-index/contracts": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.4",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.4",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src", "<rootDir>/test"],
    "testRegex": ".*\\.spec\\.ts$",
    "setupFiles": ["reflect-metadata"],
    "moduleFileExtensions": ["ts", "js", "json"]
  }
}
