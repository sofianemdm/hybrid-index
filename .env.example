# Copier en .env (jamais committé). Aucun secret réel ici.

# --- api ---
API_PORT=3000
DATABASE_URL=postgres://hybrid:hybrid@localhost:5432/hybrid_index
REDIS_URL=redis://localhost:6379
SCORE_SERVICE_URL=http://localhost:3001

# --- score-service ---
SCORE_SERVICE_PORT=3001

# --- intégrations ---
# Connexion Google : créer un OAuth Client (type "Web") sur console.cloud.google.com,
# puis renseigner l'ID client ici. Tant que vide, l'endpoint /v1/auth/google renvoie 401.
GOOGLE_CLIENT_ID=
# FCM_* / POSTHOG_KEY / SENTRY_DSN / APPLE_* ...
