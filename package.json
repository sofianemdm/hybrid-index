{
  "name": "hybrid-index",
  "version": "0.0.0",
  "private": true,
  "description": "HYBRID INDEX — monorepo (Flutter app + NestJS api + score-service versionné)",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.61.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@prisma/client",
      "prisma",
      "@prisma/engines"
    ]
  }
}
