{
  "name": "@hybrid-index/scoring-core",
  "version": "0.0.0",
  "private": true,
  "description": "Logique PURE du HYBRID INDEX (percentile, courbe f, sous-score, agrégation attribut/Index). Aucune dépendance infra — testable en isolation (exigence DoD).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
